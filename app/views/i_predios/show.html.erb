<div class="container">
  <%= render "shared/notice" %>
  <div class="card border-0 shadow shadow-sm">
    <div class="card-header border-0 d-flex justify-content-between">
      <span class="fs-4">Visualizar I Predio</span>
    </div>
    <div class="card-body">
      <div id="<%= dom_id @i_predio %>">
              
          <p>
            <strong>Nome Fantasia:</strong>
            <%= @i_predio.nome_fantasia %>
          </p>
              
          <p>
            <strong>Cnpj:</strong>
            <%= @i_predio.cnpj %>
          </p>
              
          <p>
            <strong>G Municipio:</strong>
            <%= @i_predio.g_municipio %>
          </p>
     
      </div>
    </div>
    <div class="card-footer border-0 d-flex justify-content-between">
      <div>
        <%= link_to edit_i_predio_path(@i_predio), class: "btn btn-primary" do %>
          <i class="bi bi-pencil-square"></i> Editar
        <% end %>
        <%= link_to "Voltar", i_predios_path, class: "btn btn-secondary" %>
      </div>
      <%= button_to "Deletar", @i_predio, method: :delete, class: "btn btn-outline-danger border-0" %>
    </div>
  </div>
</div>
