<div class="container">
  <%= render "shared/notice" %>
  <div class="card border-0 shadow shadow-sm">
    <div class="card-header border-0 d-flex justify-content-between">
      <span class="fs-4">Visualizar R Contrato Servidor</span>
    </div>
    <div class="card-body">
      <div id="<%= dom_id @r_contrato_servidor %>">
              
          <p>
            <strong>Matricula:</strong>
            <%= @r_contrato_servidor.matricula %>
          </p>
              
          <p>
            <strong>G Pessoa:</strong>
            <%= @r_contrato_servidor.g_pessoa %>
          </p>
              
          <p>
            <strong>R Cargo:</strong>
            <%= @r_contrato_servidor.r_cargo %>
          </p>
     
      </div>
    </div>
    <div class="card-footer border-0 d-flex justify-content-between">
      <div>
        <%= link_to edit_r_contrato_servidor_path(@r_contrato_servidor), class: "btn btn-primary" do %>
          <i class="bi bi-pencil-square"></i> Editar
        <% end %>
        <%= link_to "Voltar", r_contrato_servidores_path, class: "btn btn-secondary" %>
      </div>
      <%= button_to "Deletar", @r_contrato_servidor, method: :delete, class: "btn btn-outline-danger border-0" %>
    </div>
  </div>
</div>
