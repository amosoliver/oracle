<%= render "shared/context_nav", title: t("activerecord.models.#{IAmbientePredial.model_name.i18n_key}.other") do %>
  <span class="breadcrumb-item">
    <%= link_to t("activerecord.models.#{IPredio.model_name.i18n_key}.other"), i_predios_path, class: "text-dark" %>
  </span>
  <span class="breadcrumb-item">
    <%= link_to t("activerecord.models.#{IAmbientePredial.model_name.i18n_key}.other"), i_predio_i_ambientes_prediais_path(@i_predio), class: "text-dark" %>
  </span>
  <span class="breadcrumb-item active">
    <%= t("helpers.submit.#{params[:action]}") %>
  </span>
<% end %>

<%= simple_form_for [@i_predio, @i_ambiente_predial] do |f| %>
  <div class="card">
    <div class="card-header">
      <h5 class="my-0">
        <%= @i_ambiente_predial.new_record? ? "Incluir " : "Editar " %>
        <%= t("activerecord.models.#{IAmbientePredial.model_name.i18n_key}.one") %>
      </h5>
    </div>

    <div class="card-body">
      <%= f.error_notification %>
      <%= f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present? %>
      <%= render "shared/notice" %>

      <div class="row">
        <div class="col-12">
          <%= f.input :descricao, input_html: { class: "keyup" } %>
        </div>
        <!-- Removido o select do prédio pois o prédio já está definido no contexto -->
        <%= f.hidden_field :i_predio_id, value: @i_predio.id %>
      </div>
    </div>

    <div class="card-footer">
      <%= f.button :submit, class: "btn btn-primary" %>
      <%= link_to "Voltar", i_predio_i_ambientes_prediais_path(@i_predio), class: "btn btn-light" %>
    </div>
  </div>
<% end %>
