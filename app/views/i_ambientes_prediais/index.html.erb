<%= render "shared/context_nav", title: t("activerecord.models.#{IAmbientePredial.model_name.i18n_key}.other"), new_path: new_i_predio_i_ambiente_predial_path(@i_predio) do  %>
  <span class="breadcrumb-item active"><%= t("activerecord.models.#{IAmbientePredial.model_name.i18n_key}.other") %></span>
<% end %>
<div class="card">
  <div class="card-header d-flex">
<%= search_form_for @q, url: i_predio_i_ambientes_prediais_path(@i_predio), html: { class: "d-flex gap-2", autocomplete: "off" } do |f| %>
      <%= f.search_field :descricao_cont, class: "form-control", placeholder: t("activerecord.attributes.i_ambiente_predial.descricao") %>
      <%= f.button(type: 'submit', class: 'btn btn-info') { tag.i(class: 'ph-magnifying-glass') } %>
      <%= link_to  tag.i(class: 'ph-x-circle'), i_predio_i_ambientes_prediais_path, class: "btn btn-light" if params[:q] %>
    <% end %>      
  </div>
  <div class="card-body">
    <%= render "shared/notice" %>
    <div class= "table-responsive">
      <table class="table table-sm table-bordered table-striped">        
        <thead>
          <th class="text-center col-1">Ações</th>
          <tr>
            
              
                <th><%= sort_link(@q, :descricao, t("activerecord.attributes.i_ambiente_predial.descricao")) %></th>
              
              
                <th><%= sort_link(@q, :i_predio, t("activerecord.attributes.i_ambiente_predial.i_predio")) %></th>
              
            
          </tr>
        </thead>
        <tbody>
          <% @i_ambientes_prediais.each do |i_ambiente_predial| %>
            <tr>
              <td class="text-center">
                <div class="dropdown-toggle">
                  <a href="#" class="text-body dropdown" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="ph-gear"></i>
                  </a>
                  <div class="dropdown-menu" style="">
                    <div class="dropdown-header">Opções</div>
                    <%= link_to edit_i_ambiente_predial_path(i_ambiente_predial), class: "dropdown-item" do %>
                      <i class="ph-pen me-2"></i> Editar
                    <% end %>
                    <%= form_for i_ambiente_predial, method: :delete do |f| %>
                      <a class="dropdown-item hand-pointer " data-confirm-delete="<%= i_predio_i_ambiente_predial_path(i_ambiente_predial) %>" data-csrf-token="<%= form_authenticity_token %>">
                        <i class="ph-trash-simple me-2"></i>Excluir
                      </a>
                    <% end %>
                  </div>
                </div>
              </td>
                
                  <td><%= i_ambiente_predial.descricao %></td>
                
                
                  <td><%= i_ambiente_predial.i_predio %></td>
                
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
  <div class="card-footer">
    <%= render "shared/pagy", pagy: @pagy %>
  </div>
</div>
