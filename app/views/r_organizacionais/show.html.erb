<div class="container">
  <%= render "shared/notice" %>
  <div class="card border-0 shadow shadow-sm">
    <div class="card-header border-0 d-flex justify-content-between">
      <span class="fs-4">Visualizar R Organizacional</span>
    </div>
    <div class="card-body">
      <div id="<%= dom_id @r_organizacional %>">
              
          <p>
            <strong>Descricao:</strong>
            <%= @r_organizacional.descricao %>
          </p>
              
          <p>
            <strong>R Tipo Organizacional:</strong>
            <%= @r_organizacional.r_tipo_organizacional %>
          </p>
     
      </div>
    </div>
    <div class="card-footer border-0 d-flex justify-content-between">
      <div>
        <%= link_to edit_r_organizacional_path(@r_organizacional), class: "btn btn-primary" do %>
          <i class="bi bi-pencil-square"></i> Editar
        <% end %>
        <%= link_to "Voltar", r_organizacionais_path, class: "btn btn-secondary" %>
      </div>
      <%= button_to "Deletar", @r_organizacional, method: :delete, class: "btn btn-outline-danger border-0" %>
    </div>
  </div>
</div>
